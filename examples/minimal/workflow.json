{
  "version": 1,
  "goal": "Take a user topic, analyze it via a small subflow, and emit a final summary.",
  "nodes": [
    {
      "id": "kickoff",
      "exec": "inline",
      "node": "./nodes/kickoff",
      "purpose": "Capture the topic and the user's intent."
    },
    {
      "id": "analyze",
      "ref": "./subgraphs/analyze",
      "purpose": "Run the analysis sub-flow on the captured topic.",
      "inputMap": { "topic": "$.outputs.kickoff.topic" },
      "outputMap": { "findings": "$.outputs.refine.findings" }
    },
    {
      "id": "finish",
      "exec": "inline",
      "node": "./nodes/finish",
      "purpose": "Compose the final conclusion."
    },
    {
      "id": "hotfix",
      "exec": "inline",
      "node": "./nodes/hotfix",
      "purpose": "Side-quest entry for emergency fixes the user might request mid-flow."
    }
  ],
  "edges": [
    { "from": "__start__", "to": "kickoff" },
    { "from": "kickoff", "to": "analyze" },
    { "from": "analyze", "to": "finish" },
    { "from": "finish", "to": "__end__" },
    { "from": "hotfix", "to": "__end__" }
  ],
  "entries": [
    {
      "id": "fix_first",
      "target": "hotfix",
      "description": "Pause the main flow to handle a hotfix the user just raised.",
      "mode": "modal"
    }
  ]
}
