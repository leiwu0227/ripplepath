{
  "name": "ripplegraph",
  "version": "0.0.1",
  "description": "A lightweight, host-agent-driven workflow framework. The graph owns flow; the LLM is free within nodes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ripplegraph": "./bin/ripplegraph",
    "ripplegraph-demo": "./bin/ripplegraph-demo"
  },
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "scripts": {
    "build": "node ./node_modules/typescript/lib/tsc.js",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
